# Application
NODE_ENV=production
PORT=6002

# Database
MONGODB_URI=mongodb://localhost:27017/rationsweb

# Security
# Generate secure keys using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_secure_jwt_access_secret_here
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here
CLIENT_ORIGINS=https://admin.yourdomain.com,https://yourdomain.com

# Social Integrations
IG_CLIENT_ID=
IG_CLIENT_SECRET=
IG_REDIRECT_URI=
YT_CLIENT_ID=
YT_CLIENT_SECRET=
SOCIAL_SYNC_ENABLED=true
